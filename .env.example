# ===== REQUIRED: API KEYS =====
# NVIDIA API key - Get one at: https://build.nvidia.com/
NVIDIA_API_KEY=

# TAVILY API key (for financial news search) - Get one at: https://tavily.com/
TAVILY_API_KEY=

# ===== NVIDIA API SETTINGS =====
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ===== TAVILY API SETTINGS =====
TAVILY_BASE_URL=https://api.tavily.com/search
TAVILY_TOPIC=finance
TAVILY_SEARCH_DEPTH=advanced

# ===== PROXY CONFIGURATION =====
# Set to 'true' to enable proxy, 'false' for direct connection
USE_PROXY=true

# Proxy server address (e.g., 172.31.2.4)
PROXY_ADDRESS=

# Proxy server port (e.g., 8080)
PROXY_PORT=8080

# ===== NETWORK SETTINGS =====
# Connection timeout in seconds
CONNECTION_TIMEOUT=10

# ===== DATABASE SETTINGS =====
# Path to SQLite database for long-term memory
MEMORY_DB_PATH=trading_memory.db
